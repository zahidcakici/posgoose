{
  "name": "posgoose",
  "version": "0.1.0",
  "description": "PostgreSQL JSONB ODM — drop-in replacement for Mongoose",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json",
    "build:watch": "tsc -p tsconfig.cjs.json --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "postgresql",
    "postgres",
    "jsonb",
    "mongoose",
    "odm",
    "orm",
    "mongodb-replacement"
  ],
  "author": "Zahid Cakici <zahid.cakici@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zahidcakici/posgoose"
  },
  "dependencies": {
    "pg": "^8.21.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^11.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
